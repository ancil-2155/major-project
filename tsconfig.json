{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "react-native-gifted-chat": [
        "src/types/shims/react-native-gifted-chat.d.ts"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "acams-chat-backend"
  ]
}
