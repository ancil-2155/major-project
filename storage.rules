rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile Photos
    // Users can upload their own photo. Anyone can read it to display in the UI.
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
