rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    // Normal students can read/write only their own data
    // Admins/Teachers might need read access later
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Face Embeddings collection
    // Protected: Students can create their own upon enrollment but CANNOT read it back.
    // This prevents malicious extraction of embeddings by logged-in users.
    match /faceEmbeddings/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      // Future: allow read if user is a teacher running live attendance
      allow read, update, delete: if false; 
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
